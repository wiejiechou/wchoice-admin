# 線上環境平台打包路徑
VITE_PUBLIC_PATH = /

# 線上環境路由歷史模式（Hash模式傳"hash"、HTML5模式傳"h5"、Hash模式帶base參數傳"hash,base參數"、HTML5模式帶base參數傳"h5,base參數"）
VITE_ROUTER_HISTORY = "hash"

# 是否在打包時使用cdn替換本地庫 替換 true 不替換 false
VITE_CDN = false

# 是否啟用gzip壓縮或brotli壓縮（分成兩種情況，刪除原始檔案和不刪除原始檔案）
# 壓縮時不刪除原始檔案的設定：gzip、brotli、both（同時開啟 gzip 與 brotli 壓縮）、none（不開啟壓縮，預設）
# 壓縮時刪除原始檔案的設定：gzip-clear、brotli-clear、both-clear（同時開啟 gzip 與 brotli 壓縮）、none（不開啟壓縮，預設）
VITE_COMPRESSION = "none"
